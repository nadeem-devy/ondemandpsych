# Database (same Neon PostgreSQL as Next.js app)
DATABASE_URL=postgresql+asyncpg://neondb_owner:YOUR_PASSWORD@ep-cool-mode-a4289nsz-pooler.us-east-1.aws.neon.tech/neondb?ssl=require

# OpenAI
OPENAI_API_KEY=sk-...

# Redis (for Celery task queue)
REDIS_URL=redis://localhost:6379/0

# AWS S3 (for document storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=ondemandpsych-rag-docs

# Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
MAX_CONCURRENT_EMBEDDINGS=10
BATCH_SIZE=50

# Whisper (for video transcription)
WHISPER_MODEL=base
